# ----------------------------------------------------------------------------
# Harborline Systems — environment variables
# Copy this file to `.env.local` and fill in real values for production.
# Everything has a safe default in development, so the site runs without these.
# ----------------------------------------------------------------------------

# Public site URL — used for absolute SEO / OpenGraph URLs and canonical links.
# In production set this to your real domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://harborlinesystems.com

# Booking link (Calendly, Cal.com, SavvyCal, etc.).
# If left empty, "Book a Free Consultation" buttons fall back to the /contact page.
NEXT_PUBLIC_BOOKING_URL=

# ----------------------------------------------------------------------------
# Contact form email delivery (server-side only — never expose to the client).
# The /api/contact route reads these. If EMAIL_PROVIDER is unset, submissions
# are logged to the server console so you can develop without an email account.
#
# Supported placeholder integrations (see app/api/contact/route.ts):
#   EMAIL_PROVIDER=resend     -> uses RESEND_API_KEY
#   EMAIL_PROVIDER=sendgrid   -> uses SENDGRID_API_KEY
# ----------------------------------------------------------------------------
EMAIL_PROVIDER=
RESEND_API_KEY=
SENDGRID_API_KEY=

# Where contact form submissions should be delivered, and the from address.
CONTACT_TO_EMAIL=hello@harborlinesystems.com
CONTACT_FROM_EMAIL=website@harborlinesystems.com
